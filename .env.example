# ========================================
# FLEXJOB - VARIABLES D'ENVIRONNEMENT (EXEMPLE)
# ========================================
# Copiez ce fichier en .env et adaptez les valeurs

# Base de données MySQL
DATABASE_URL="mysql://votre_user:votre_password@localhost:3306/job_platform"
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="votre_user"
DB_PASSWORD="votre_password"
DB_NAME="job_platform"

# JWT Authentication (CHANGEZ CES VALEURS EN PRODUCTION)
JWT_SECRET="votre-cle-jwt-secrete-tres-longue-et-complexe"
JWT_EXPIRES_IN="7d"

# Next.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="votre-secret-nextauth-tres-securise"

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Configuration Email (optionnel)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="votre-email@gmail.com"
SMTP_PASSWORD="votre-mot-de-passe-app"
EMAIL_FROM="noreply@flexjob.sn"

# Upload Files
MAX_FILE_SIZE="5242880"  # 5MB
UPLOAD_DIR="./public/uploads"

# Session
SESSION_SECRET="votre-secret-session-tres-securise"

# API Configuration
API_BASE_URL="http://localhost:3000/api"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Rate Limiting
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="900000"  # 15 minutes

# Logging
LOG_LEVEL="info"
